{
  "buildCommand": "npm install",
  "outputDirectory": "./",
  "env": {
    "NODE_ENV": "production",
    "PORT": "5000",
    "DB_HOST": "@db_host",
    "DB_USER": "@db_user",
    "DB_PASSWORD": "@db_password",
    "DB_NAME": "@db_name",
    "JWT_SECRET": "@jwt_secret"
  },
  "functions": {
    "src/server.js": {
      "memory": 1024,
      "maxDuration": 300
    }
  }
}
